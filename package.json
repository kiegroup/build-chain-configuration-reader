    "braces": "^3.0.3",
    "micromatch": "^4.0.8",
    "minimatch": "^3.1.4",
    "semver": "^7.5.2",
    "word-wrap": "^1.2.4",
    "brace-expansion": "^2.0.1",
    "cross-spawn": "^7.0.5",
    "picomatch": "^4.0.2",
    "lodash": "^4.17.21",
